pipeline {
    agent any

    stages {

        stage('Build') {
            steps {
                sh '''
                docker build -t jenkins-php-pipeline .
                '''
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                docker stop php-cont || true
                docker rm php-cont || true

                docker run -dp 3000:80 \
                    --name php-cont \
                    jenkins-php-pipeline
                '''
            }
        }
    }
}